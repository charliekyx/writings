# 复制为 .env 或在 GCP Secret 中注入（勿提交真实 token）
WISE_API_TOKEN=
WISE_PROFILE_ID=
WISE_API_BASE=https://api.wise.com

STRICT_AUTO=1

# M3：仅各银行官网牌价与手续费；requests 失败则用 Playwright 加载同一 URL（需 pip install playwright && playwright install chromium）
# M3_HTTP_TIMEOUT=45
# M3_BANK_HTML_RETRIES=1
# Maybank 极慢时可加大：M3_PLAYWRIGHT_TIMEOUT_MS=300000
# 仅 requests、不装浏览器时用（Maybank 常失败）：M3_USE_REQUESTS_ONLY=1

# Playwright Chromium：默认加 --disable-http2 --disable-quic（缓解 Maybank 等 ERR_HTTP2_PROTOCOL_ERROR）
# 覆盖示例：PLAYWRIGHT_CHROMIUM_ARGS=--disable-http2 --disable-quic
# 不用额外参数（不推荐）：PLAYWRIGHT_CHROMIUM_ARGS=-
# M4/M5/M8：Dockerfile.research 已安装 Chromium；本机需自行 playwright install chromium
# 官网不可达时跳过 Maybank TT 采集（仍跑 CIMB；本地省时间）
SKIP_M3_MAYBANK=0
# 不需要每次拉 Reddit 时可跳过 m7（舆情/关键词，与汇率频率可不同）
SKIP_M7=0
# 机房 IP 常被 Revolut 403 时可设跳过 m8
SKIP_M8=0
